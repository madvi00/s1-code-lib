<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!--
      .zip 다운로드 활성화
      - remove 먼저: .zip MIME가 서버 레벨에 이미 등록되어 있을 때
        web.config에서 중복 add 하면 HTTP 500.19(중복 항목) 오류가 나므로,
        항상 remove 후 add 하여 안전하게 덮어쓴다.
    -->
    <staticContent>
      <remove fileExtension=".zip" />
      <mimeMap fileExtension=".zip" mimeType="application/zip" />

      <!-- 디자인 토큰/폰트 등 정적 자원도 명시적으로 보장 -->
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".otf" />
      <mimeMap fileExtension=".otf" mimeType="font/otf" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <security>
      <requestFiltering>
        <!-- 큰 zip(약 26MB) 응답에는 영향 없으나, 혹시 모를 차단 방지를 위해 한도를 넉넉히 -->
        <requestLimits maxAllowedContentLength="104857600" />
        <fileExtensions allowUnlisted="true">
          <!-- .zip 확장자가 거부 목록에 있다면 명시적으로 허용 -->
          <remove fileExtension=".zip" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- 정적 파일 핸들러가 zip을 직접 응답하도록 보장 -->
    <handlers accessPolicy="Read, Script" />

  </system.webServer>
</configuration>
